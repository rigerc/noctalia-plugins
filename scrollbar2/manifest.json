{
  "id": "scrollbar2",
  "name": "Scrollbar2",
  "version": "1.0.0",
  "minNoctaliaVersion": "4.6.6",
  "author": "rigerc",
  "license": "MIT",
  "repository": "https://github.com/noctalia-dev/noctalia-plugins",
  "description": "A configurable window bar with equal-width segments, animated focus tracking, and optional floating panel placement.",
  "tags": [
    "Bar",
    "Utility"
  ],
  "entryPoints": {
    "main": "Main.qml",
    "barWidget": "BarWidget.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "display": {
        "mode": "bar",
        "spaceMode": "reserve",
        "offsetH": 0,
        "offsetV": 0,
        "scale": 1.0,
        "margin": 0,
        "radiusScale": 1.0,
        "background": {
          "color": "none",
          "opacity": 0
        },
        "gradientEnabled": false,
        "gradient": {
          "color": "none",
          "opacity": 0
        },
        "gradientDirection": "vertical"
      },
      "filtering": {
        "onlySameOutput": true,
        "onlyActiveWorkspaces": true
      },
      "track": {
        "position": "bottom",
        "verticalAlign": "bottom",
        "thickness": 6,
        "borderRadius": 3,
        "shadowEnabled": true,
        "fill": {
          "color": "surface",
          "opacity": 1
        },
        "separatorColor": "outline",
        "width": 40,
        "segmentSpacing": 4
      },
      "focusLine": {
        "thickness": 6,
        "borderRadius": 3,
        "verticalAlign": "bottom",
        "shadowEnabled": true,
        "opacity": 1,
        "colors": {
          "focused": "primary",
          "hover": "hover",
          "default": "surface-variant"
        }
      },
      "window": {
        "showIcon": true,
        "showTitle": true,
        "focusedOnly": false,
        "focusedAlign": "segment",
        "borderRadius": 6,
        "margin": 2,
        "font": "JetBrains Mono",
        "fontSize": 11,
        "iconScale": 1,
        "titleScale": 1,
        "iconAlign": "center",
        "titleAlign": "left",
        "paddingLeft": 7,
        "paddingRight": 7,
        "fontWeights": {
          "focused": "semibold",
          "hover": "medium",
          "default": "medium"
        },
        "iconColors": {
          "focused": "on-surface",
          "hover": "on-hover",
          "default": "on-surface-variant"
        },
        "titleColors": {
          "focused": "on-surface",
          "hover": "on-hover",
          "default": "on-surface-variant"
        }
      },
      "animation": {
        "enabled": true,
        "speed": 420
      }
    }
  }
}
