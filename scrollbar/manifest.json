{
  "id": "scrollbar",
  "name": "Scrollbar",
  "version": "1.0.0",
  "minNoctaliaVersion": "4.6.6",
  "author": "OpenAI",
  "license": "MIT",
  "repository": "https://github.com/noctalia-dev/noctalia-plugins",
  "description": "A focused, scrolling window strip for the bar with centered selection and passive overflow fades.",
  "tags": [
    "Bar",
    "Utility"
  ],
  "entryPoints": {
    "main": "Main.qml",
    "barWidget": "BarWidget.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "onlySameOutput": true,
      "onlyActiveWorkspaces": true,
      "enableReorder": true,
      "debugLogging": false,
      "maxWidgetWidth": 40,
      "slotWidth": 112,
      "showTitle": true,
      "iconScale": 0.8,
      "edgeFadeSize": 18,
      "edgeFadeMidpoint": 0.45,
      "edgeFadeMidOpacity": 40,
      "showTrackLine": true,
      "accentColor": "primary",
      "inactiveOpacity": 45,
      "slotSpacingUnits": 1,
      "radiusScale": 1.0,
      "hoverFillColor": "hover",
      "hoverBorderColor": "outline",
      "hoverTextColor": "on-hover",
      "hoverFillOpacity": 55,
      "hoverScalePercent": 2.5,
      "hoverTransitionDurationMs": 120,
      "focusedFillOpacity": 92,
      "focusedFillColor": "primary",
      "focusedBorderColor": "primary",
      "focusedTextColor": "on-primary",
      "showFocusedFill": true,
      "unfocusedFillOpacity": 8,
      "unfocusedBorderOpacity": 45,
      "unfocusedFillColor": "surface-variant",
      "unfocusedBorderColor": "outline",
      "unfocusedTextColor": "on-surface",
      "showUnfocusedFill": true,
      "showFocusedBorder": true,
      "focusedBorderOpacity": 100,
      "showHoverBorder": true,
      "hoverBorderOpacity": 100,
      "showUnfocusedBorder": true,
      "trackOpacity": 35,
      "showFocusLine": true,
      "focusLineColor": "secondary",
      "focusLineOpacity": 96,
      "focusLineThickness": 2,
      "focusLineAnimationMs": 120,
      "centerFocusedWindow": true,
      "centerAnimationMs": 200,
      "showIcons": true,
      "titleFontFamily": "",
      "titleFontSize": 0,
      "titleFontWeight": "default",
      "iconTintColor": "none",
      "iconTintOpacity": 100,
      "backgroundColor": "none",
      "backgroundOpacity": 0
    }
  }
}
