{
  "id": "meta-package-manager-tray",
  "name": "Meta Package Manager Tray",
  "version": "1.0.0",
  "minNoctaliaVersion": "4.6.6",
  "author": "OpenAI",
  "license": "MIT",
  "repository": "https://github.com/noctalia-dev/noctalia-plugins",
  "description": "Cross-manager update monitoring and upgrades powered by meta-package-manager.",
  "tags": ["Bar", "Panel", "System", "Utility"],
  "entryPoints": {
    "main": "Main.qml",
    "barWidget": "BarWidget.qml",
    "panel": "Panel.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "enabledManagerIds": ["pacman", "paru", "flatpak", "npm", "cargo", "uv"],
      "refreshIntervalMinutes": 30,
      "iconName": "package",
      "iconColor": "primary",
      "showCountText": true,
      "countTextPosition": "right",
      "countTextFontFamily": "",
      "countTextFontWeight": "bold",
      "countTextScale": 1.0,
      "countColor": "secondary",
      "errorColor": "destructive",
      "enableNotifications": false,
      "terminalCommand": "foot -e sh -lc '{}'"
    }
  }
}
