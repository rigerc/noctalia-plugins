{
  "id": "taskbar2",
  "name": "Taskbar 2",
  "version": "1.0.0",
  "minNoctaliaVersion": "4.6.6",
  "author": "OpenAI",
  "license": "MIT",
  "repository": "https://github.com/rigerc/noctalia-plugins",
  "description": "A standalone taskbar bar widget ported from Noctalia Shell, with improvements.",
  "tags": [
    "Bar",
    "Utility"
  ],
  "entryPoints": {
    "barWidget": "BarWidget.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "onlySameOutput": true,
      "onlyActiveWorkspaces": true,
      "hideMode": "hidden",
      "colorizeIcons": false,
      "showTitle": false,
      "titleWidth": 120,
      "showPinnedApps": true,
      "smartWidth": true,
      "maxTaskbarWidth": 40,
      "iconScale": 0.8,
      "hoverIconScaleMultiplier": 1.0,
      "hoverItemScalePercent": 0,
      "itemGapUnits": 2,
      "titleFontFamily": "",
      "titleFontScale": 1.0,
      "titleFontWeight": "medium",
      "itemColors": {
        "default": {
          "background": "none",
          "border": "none",
          "text": "none"
        },
        "hovered": {
          "background": "none",
          "border": "none",
          "text": "none"
        },
        "focused": {
          "background": "none",
          "border": "none",
          "text": "none"
        },
        "inactive": {
          "background": "none",
          "border": "none",
          "text": "none"
        }
      },
      "groupApps": false,
      "groupClickAction": "cycle",
      "groupContextMenuMode": "extended",
      "groupIndicatorStyle": "number",
      "groupByWorkspaceIndex": false,
      "showWorkspaceSeparators": true,
      "workspaceSeparatorShowLabel": true,
      "workspaceSeparatorShowDivider": true,
      "workspaceSeparatorPrefix": "",
      "workspaceSeparatorSuffix": "",
      "workspaceSeparatorDividerMode": "line",
      "workspaceSeparatorDividerChar": "|",
      "workspaceSeparatorDividerIcon": "minus",
      "workspaceSeparatorShowForFirst": false
    }
  }
}
